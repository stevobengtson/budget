# Build artifacts
bin/
data/
tmp/
*.exe

# Generated Templ Go files (rebuilt inside the image to avoid stale state).
internal/web/views/*_templ.go
pkg/shadcntempl/**/*_templ.go

# Generated Tailwind output (rebuilt inside the image from input.css).
internal/web/static/app.css

# Local SQLite databases
*.db
*.db-wal
*.db-shm

# Editor / VCS noise
.git/
.gitignore
.idea/
.vscode/
.DS_Store

# Local docs / screenshots not needed at runtime.
screenshots/
docs/
tmp/

# Test caches
*.test
*.out
