package views

import (
	"fmt"
	"strconv"
	"time"

	"github.com/sbengtson/budget/internal/money"
	"github.com/sbengtson/budget/internal/store"
	"github.com/sbengtson/budget/pkg/shadcntempl/button"
	"github.com/sbengtson/budget/pkg/shadcntempl/card"
	"github.com/sbengtson/budget/pkg/shadcntempl/dialog"
	"github.com/sbengtson/budget/pkg/shadcntempl/input"
	"github.com/sbengtson/budget/pkg/shadcntempl/table"
)

type IncomeData struct {
	Month     string // YYYY-MM
	PrevMonth string
	NextMonth string
	Today     string
	Rows      []store.Income
	Total     int64
	Actual    int64
	Budgeted  int64
}

templ IncomePage(d IncomeData) {
	@Layout("Income · Budget", "budget") {
		<div class="mb-4 flex items-center justify-between gap-4">
			<h1 class="text-2xl font-semibold tracking-tight">Income · { incomeMonthLabel(d.Month) }</h1>
			<div class="flex items-center gap-2">
				@button.Link("/budget/income?month="+d.PrevMonth, button.Props{Variant: button.VariantOutline, Size: button.SizeSmall}) {
					‹ prev
				}
				@button.Link("/budget/income?month="+d.Today, button.Props{Variant: button.VariantOutline, Size: button.SizeSmall}) {
					today
				}
				@button.Link("/budget/income?month="+d.NextMonth, button.Props{Variant: button.VariantOutline, Size: button.SizeSmall}) {
					next ›
				}
			</div>
		</div>

		<div class="mb-6 grid grid-cols-2 gap-3 md:grid-cols-4">
			@incomeStat("Estimated", money.Format(d.Total), "text-emerald-500")
			@incomeStat("Actual", money.Format(d.Actual), "text-emerald-500")
			@incomeStat("Budgeted", money.Format(d.Budgeted), "")
			@incomeStatSigned("Remain", d.Total-d.Budgeted)
		</div>

		<div class="mb-3 flex flex-wrap items-center justify-between gap-3">
			<p class="text-xs text-muted-foreground">
				<a class="underline underline-offset-4 hover:text-foreground" href={ templ.URL("/budget?month=" + d.Month) }>← back to budget</a>
			</p>
			<div class="flex flex-wrap items-center gap-2">
				@button.Button(button.Props{
					Variant: button.VariantOutline,
					Size:    button.SizeSmall,
					Attrs: templ.Attributes{
						"hx-post":    "/budget/income/copy-prev?month=" + d.Month,
						"hx-confirm": "Copy all entries from the previous month into this one?",
						"title":      "Copy every entry from " + d.PrevMonth + " into this month",
					},
				}) {
					← copy from prev
				}
				@button.Link("/budget/income/new?month="+d.Month, button.Props{
					Size: button.SizeSmall,
					Attrs: templ.Attributes{
						"hx-get":    "/budget/income/new?month=" + d.Month,
						"hx-target": "#modal",
						"hx-swap":   "innerHTML",
					},
				}) {
					+ new
				}
			</div>
		</div>

		if len(d.Rows) == 0 {
			<p class="text-sm text-muted-foreground">
				No income entries yet for this month. Add one with the <strong>+ new</strong> button.
			</p>
		} else {
			@table.Table(table.Props{}) {
				@table.Header(table.Props{}) {
					@table.Row(table.Props{}) {
						@table.Head(table.Props{}) { Source }
						@table.Head(table.Props{Class: "text-right"}) { Amount }
						@table.Head(table.Props{}) { }
					}
				}
				<tbody id="income-rows" class="[&_tr:last-child]:border-0">
					for _, r := range d.Rows {
						@IncomeRow(d.Month, r)
					}
				</tbody>
			}
		}
	}
}

templ incomeStat(label, value, valueClass string) {
	@card.Card(card.Props{Class: "p-4"}) {
		<div class="text-xs uppercase tracking-wide text-muted-foreground">{ label }</div>
		<div class={ "mt-1 text-lg font-semibold tabular-nums " + valueClass }>{ value }</div>
	}
}

templ incomeStatSigned(label string, cents int64) {
	@card.Card(card.Props{Class: "p-4"}) {
		<div class="text-xs uppercase tracking-wide text-muted-foreground">{ label }</div>
		<div class="mt-1 text-lg font-semibold tabular-nums">
			@SignedMoney(cents)
		</div>
	}
}

templ IncomeRow(month string, r store.Income) {
	@table.Row(table.Props{Attrs: templ.Attributes{"id": fmt.Sprintf("income-%d", r.ID)}}) {
		@table.Cell(table.Props{Class: "font-medium"}) { { r.Name } }
		@table.Cell(table.Props{Class: "text-right tabular-nums text-emerald-500"}) {
			{ money.Format(r.AmountCents) }
		}
		@table.Cell(table.Props{Class: "whitespace-nowrap"}) {
			@button.Link(fmt.Sprintf("/budget/income/%d/edit?month=%s", r.ID, month), button.Props{
				Variant: button.VariantOutline,
				Size:    button.SizeSmall,
				Class:   "mr-1",
				Attrs: templ.Attributes{
					"hx-get":    fmt.Sprintf("/budget/income/%d/edit?month=%s", r.ID, month),
					"hx-target": "#modal",
					"hx-swap":   "innerHTML",
				},
			}) {
				edit
			}
			@button.Button(button.Props{
				Variant: button.VariantDestructive,
				Size:    button.SizeSmall,
				Attrs: templ.Attributes{
					"hx-delete":  fmt.Sprintf("/budget/income/%d?month=%s", r.ID, month),
					"hx-target":  fmt.Sprintf("#income-%d", r.ID),
					"hx-swap":    "outerHTML",
					"hx-confirm": "Delete?",
				},
			}) {
				×
			}
		}
	}
}

type IncomeFormData struct {
	Editing bool
	ID      int64
	Month   string
	Name    string
	Amount  string
}

templ IncomeForm(d IncomeFormData) {
	@dialog.Content(dialog.Props{}) {
		<form
			if d.Editing {
				hx-put={ fmt.Sprintf("/budget/income/%d?month=%s", d.ID, d.Month) }
			} else {
				hx-post={ "/budget/income?month=" + d.Month }
			}
			hx-target="#modal"
			hx-swap="innerHTML"
			class="grid gap-4"
		>
			@dialog.Header(dialog.Props{}) {
				@dialog.Title(dialog.Props{}) {
					if d.Editing {
						Edit income
					} else {
						New income
					}
				}
				@dialog.Description(dialog.Props{}) {
					{ incomeMonthLabel(d.Month) }
				}
			}
			<div class="grid gap-3">
				@formRow("income-name", "Source") {
					@input.Input(input.Props{
						ID:          "income-name",
						Name:        "name",
						Value:       d.Name,
						Required:    true,
						Placeholder: "Salary",
						Attrs:       templ.Attributes{"autofocus": ""},
					})
				}
				@formRow("income-amount", "Amount") {
					@input.Input(input.Props{
						ID:          "income-amount",
						Name:        "amount",
						Value:       d.Amount,
						Placeholder: "0.00",
						Class:       "tabular-nums",
					})
				}
			</div>
			@dialog.Footer(dialog.Props{}) {
				@button.Button(button.Props{
					Variant: button.VariantOutline,
					Type:    "button",
					Attrs:   templ.Attributes{"hx-on:click": "document.getElementById('modal').replaceChildren()"},
				}) {
					cancel
				}
				@button.Button(button.Props{Type: "submit"}) {
					save
				}
			}
		</form>
	}
}

func incomeMonthLabel(m string) string {
	t, err := time.Parse("2006-01", m)
	if err != nil {
		return m
	}
	return t.Format("January 2006")
}

// stringIDs is a helper that converts an int64 to a string for templ
// expressions; kept here so income.templ stays self-contained.
func stringIDs(v int64) string { return strconv.FormatInt(v, 10) }
